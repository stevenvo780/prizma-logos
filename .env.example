# Logos (ApiSigo) — SIGO Integration Backend
# Copy to .env and configure for your environment

# ============================================================================
# Service Configuration
# ============================================================================
NODE_ENV=development
PORT=3004

# ============================================================================
# SIGO Authentication
# ============================================================================
# SIGO API credentials for testing/development
SIGO_API_URL=https://api.sigo.com.co
SIGO_API_VERSION=v1
SIGO_CLIENT_ID=your-client-id-here
SIGO_CLIENT_SECRET=your-client-secret-here

# ============================================================================
# Nous Hub Integration
# ============================================================================
# Hub webhook secret (HMAC SHA256 signing)
HUB_WEBHOOK_SECRET=your-hub-webhook-secret-here
PRIZMA_HUB_URL=http://localhost:3007

# Allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000,https://yourdomain.com

# ============================================================================
# Persistent Idempotency Store (Redis)
# ============================================================================
# Redis connection URL for persistent idempotency keys
# If not set, defaults to redis://localhost:6379
# If Redis is unavailable, service automatically falls back to in-memory storage (dev only)
#
# Examples:
#   Local: redis://localhost:6379
#   With auth: redis://:password@host:6379
#   Redis Cloud: redis://:api-token@redis-endpoint:port
#
REDIS_URL=redis://localhost:6379

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=debug

# ============================================================================
# Development Flags
# ============================================================================
# Bypass auth in development (DO NOT use in production)
# AUTH_DISABLED=0
